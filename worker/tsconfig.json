{
  // Type-checks the Cloudflare Worker (run: npx tsc -p worker/tsconfig.json --noEmit).
  // The worker runs on the Workers runtime, so it uses @cloudflare/workers-types
  // for the runtime globals (D1Database, Fetcher, ExecutionContext, crypto, ...)
  // instead of the DOM/Node libs.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts"]
}
